<!-- .NET helper library project for the PSSqliteRoH PowerShell module. -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AssemblyName>PSSqliteRoH.Sqlite</AssemblyName>
    <RootNamespace>PSSqliteRoH.Sqlite</RootNamespace>
    <Description>Helper library for the PSSqliteRoH PowerShell module.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="7.0.13" />
  </ItemGroup>

</Project>
